# --- FinOps Project Data Security ---
# Block all raw and processed billing data (AWS CUR/GCP Exports)
data/*.csv
reports/*.csv
forecasts/*.csv

# EXCEPT the sample file for recruiter demonstration
!data/cur_sample.csv

# --- Visualization & Reporting ---
# Ignore generated charts (let others run your code to see them)
reports/*.png
notebooks/*.png
dashboards/*.json

# --- Python Environment ---
# Standard Python ignore rules for a clean repo
venv/
env/
.env
__pycache__/
*.pyc
.ipynb_checkpoints/
.python-version

# --- IDE & OS Junk ---
.vscode/
.idea/
.DS_Store
Thumbs.db
